# ── Stripe (frontend) ──────────────────────────────────────────────────────────
# Get your test publishable key from https://dashboard.stripe.com/test/apikeys
# Leave empty/unset to use Demo Mode (no real payment, still creates orders)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# Backend URL (production only – dev uses Vite proxy to localhost:5000)
VITE_API_URL=http://localhost:5000
